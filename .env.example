# 云开发数据库
TCB_ENV_ID=xxx                      # 云开发环境ID
TCB_SECRET_ID=xxx                   # 腾讯云 SecretId
TCB_SECRET_KEY=xxx                  # 腾讯云 SecretKey

# 阿里云短信
ALIYUN_ACCESS_KEY_ID=xxx
ALIYUN_ACCESS_KEY_SECRET=xxx
ALIYUN_SMS_SIGN_NAME=xxx            # 短信签名
ALIYUN_SMS_TEMPLATE_CODE=xxx        # 短信模板ID

# 微信小程序
WECHAT_APPID=xxx
WECHAT_APP_SECRET=xxx

# 微信支付
WECHAT_MCH_ID=xxx
WECHAT_API_KEY=xxx

# 百居易 PMS（从浏览器 Cookie 获取）
HOSTEX_SESSION=xxx                  # hostex_session cookie
HOSTEX_OPERATOR_ID=xxx              # operator_id cookie

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# 服务配置
PORT=7001
